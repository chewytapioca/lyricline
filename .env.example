# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash (free tier): rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Genius API ────────────────────────────────────────────────────────────────
# Get a free token at: https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token_here

# ── Cache TTLs ────────────────────────────────────────────────────────────────
# MusicBrainz data: cache for 24 hours (ms)
MB_CACHE_TTL_MS=86400000
# Sentiment results: -1 = never expire (deterministic)
SENT_CACHE_TTL_MS=-1
